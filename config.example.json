{
  "listen": "127.0.0.1:37120",
  "transport": {
    "listen": "127.0.0.1:37121"
  },
  "database": {
    "driver": "postgres",
    "dsn": "postgres://user:password@127.0.0.1:5432/database?sslmode=disable",
    "maxOpenConns": 32,
    "maxIdleConns": 16,
    "connMaxLifetimeSeconds": 1800,
    "queryTimeoutMs": 5000,
    "slowQueryMs": 100
  },
  "realtime": {
    "enabled": true,
    "pollIntervalMs": 250
  }
}
